{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist-server",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["server.ts"],
  "exclude": ["node_modules", "dist", "src"]
}
