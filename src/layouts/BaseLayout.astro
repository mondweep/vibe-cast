---
const { title = "AI Safety Academy" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style is:global>
      :root {
        --bg-color: #0f172a;
        --text-color: #f1f5f9;
        --accent-color: #38bdf8;
        --secondary-color: #1e293b;
        --card-bg: #1e293b;
        --border-color: #334155;
      }
      
      body {
        background-color: var(--bg-color);
        color: var(--text-color);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        line-height: 1.6;
        margin: 0;
      }

      .container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 2rem;
      }

      header {
        border-bottom: 1px solid var(--border-color);
        padding: 1.5rem 0;
        margin-bottom: 3rem;
      }

      .logo {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--accent-color);
        text-decoration: none;
        letter-spacing: -0.025em;
      }

      main {
        min-height: 80vh;
      }

      footer {
        margin-top: 5rem;
        padding: 3rem 0;
        border-top: 1px solid var(--border-color);
        text-align: center;
        color: #94a3b8;
        font-size: 0.875rem;
      }

      /* Markdown Content Styling */
      .prose {
        max-width: none;
      }
      .prose h1 { font-size: 2.5rem; margin-top: 0; color: #fff; }
      .prose h2 { font-size: 1.8rem; margin-top: 2.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; color: #e2e8f0; }
      .prose h3 { font-size: 1.4rem; margin-top: 2rem; color: #cbd5e1; }
      .prose p { margin-bottom: 1.25rem; color: #cbd5e1; }
      .prose ul, .prose ol { margin-bottom: 1.5rem; padding-left: 1.5rem; }
      .prose li { margin-bottom: 0.5rem; }
      .prose code { 
        background-color: #000; 
        padding: 0.2em 0.4em; 
        border-radius: 0.375rem; 
        font-family: 'JetBrains Mono', monospace; 
        font-size: 0.9em; 
        color: var(--accent-color);
      }
      .prose pre { 
        background-color: #000 !important; 
        padding: 1.5rem; 
        border-radius: 0.75rem; 
        border: 1px solid var(--border-color);
        overflow-x: auto;
        margin: 1.5rem 0;
      }
      .prose pre code { background-color: transparent; padding: 0; color: inherit; }
      .prose blockquote {
        border-left: 4px solid var(--accent-color);
        padding-left: 1.5rem;
        font-style: italic;
        margin: 2rem 0;
        color: #94a3b8;
      }
      .prose a { color: var(--accent-color); text-decoration: none; border-bottom: 1px solid rgba(56, 189, 248, 0.2); transition: border-color 0.2s; }
      .prose a:hover { border-bottom-color: var(--accent-color); }

      /* Hero Section */
      .hero {
        background: radial-gradient(circle at top right, rgba(56, 189, 248, 0.1), transparent);
        border-radius: 1.5rem;
        padding: 3rem;
        margin-bottom: 4rem;
        border: 1px solid var(--border-color);
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <a href="/" class="logo">AI SAFETY ACADEMY</a>
      </header>
      
      <main>
        <div class="prose">
          <slot />
        </div>
      </main>

      <footer>
        &copy; {new Date().getFullYear()} AI Safety Academy. Built for Gemma-4 Research.
      </footer>
    </div>
  </body>
</html>
