# Geolocation API (Browser native)
# No configuration needed - uses browser's Geolocation API

# Nominatim Geocoding API (OpenStreetMap)
# Uses public endpoint: https://nominatim.openstreetmap.org/reverse
NOMINATIM_API_BASE=https://nominatim.openstreetmap.org

# Google Generative AI (Gemini)
# Get your API key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Application Configuration
VITE_APP_NAME=Driftwise
VITE_APP_VERSION=0.1.0
VITE_LOG_LEVEL=info
