# Pi Network Explorer - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to git!

# PubNub Configuration (Real-time messaging)
# Get keys from: https://admin.pubnub.com
PUBNUB_PUBLISH_KEY=your_publish_key_here
PUBNUB_SUBSCRIBE_KEY=your_subscribe_key_here
REACT_APP_PUBNUB_SUBSCRIBE_KEY=your_subscribe_key_here

# Pi Network Configuration
# API URL for the pi.ruv.io network
PI_NETWORK_API_URL=https://pi.ruv.io

# Development Server
# Set to true to enable verbose logging
DEBUG=false
