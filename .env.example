# Copy this file to .env and fill in real values. .env is gitignored.
# Every script in this branch reads its config from environment variables.

# ─── Supabase Cloud ───
# Required by: push_to_supabase.py, seed_push_to_supabase.py
# Find these at https://supabase.com/dashboard/project/<your-ref>/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# ─── Cognitum Seed device (HTTPS API) ───
# Required by: tamper_evidence_demo.py
COGNITUM_BASE=https://cognitum-2c3c.local:8443
COGNITUM_TOKEN=your-seed-bearer-token
# Optional: cert fingerprint for pinning. Public material, safe to leave as default.
# COGNITUM_CERT_FINGERPRINT=

# ─── Seed SSH host (for log tailing) ───
# Used by: push_to_supabase.py, generate_vitals_report.py,
#          ruview_dashboard.py, vitals_dashboard.py
SEED_HOST=genesis@cognitum-2c3c.local

# ─── Local dashboard ports (optional, defaults shown) ───
# RUVIEW_PORT=8765
# VITALS_PORT=8765
# RUVIEW_LOG_PATH=/var/lib/cognitum/apps/ruview-densepose/output.log
# VITALS_REPORT_FILE=vitals_report.html
