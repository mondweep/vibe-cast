{
  "company": {
    "name": "Finabeo",
    "tagline": "Enterprise FinOps & Agentic AI Partner",
    "website": "https://www.finabeo.com",
    "description": "Enterprise FinOps consulting and Agentic AI transformation for regulated industries"
  },
  "colors": {
    "primary": {
      "name": "Navy Blue",
      "hex": "#003366",
      "rgb": "rgb(0, 51, 102)",
      "usage": "Headers, CTAs, primary UI elements, document titles"
    },
    "secondary": {
      "name": "Tech Blue",
      "hex": "#00B4D8",
      "rgb": "rgb(0, 180, 216)",
      "usage": "Accents, highlights, secondary CTAs"
    },
    "accent": {
      "name": "Gold",
      "hex": "#FFB81C",
      "rgb": "rgb(255, 184, 28)",
      "usage": "Success metrics, ROI highlights, important statistics"
    },
    "neutral": {
      "dark": {
        "name": "Dark Gray",
        "hex": "#2B2B2B",
        "rgb": "rgb(43, 43, 43)",
        "usage": "Body text, headings"
      },
      "light": {
        "name": "Light Gray",
        "hex": "#F5F5F5",
        "rgb": "rgb(245, 245, 245)",
        "usage": "Backgrounds, section dividers"
      },
      "white": {
        "name": "White",
        "hex": "#FFFFFF",
        "rgb": "rgb(255, 255, 255)",
        "usage": "Primary background"
      }
    }
  },
  "typography": {
    "heading": {
      "family": "Montserrat",
      "fallback": "Arial, sans-serif",
      "weight": "700",
      "variants": ["Bold", "SemiBold"],
      "usage": "H1, H2, H3 headlines, CTAs, emphasis"
    },
    "body": {
      "family": "Open Sans",
      "fallback": "Segoe UI, Tahoma, sans-serif",
      "weight": "400",
      "variants": ["Regular", "SemiBold"],
      "usage": "Body text, paragraphs, descriptions"
    },
    "mono": {
      "family": "IBM Plex Mono",
      "fallback": "Courier New, monospace",
      "weight": "400",
      "usage": "Code snippets, metrics, data displays"
    },
    "sizes": {
      "h1": "36-48px",
      "h2": "24-32px",
      "h3": "18-24px",
      "body": "14-16px",
      "small": "12px",
      "caption": "11px"
    }
  },
  "messaging": {
    "brand_voice": {
      "personality": ["Professional", "Approachable", "Confident", "Educational", "Human-Centric"],
      "tone": "Expert yet accessible",
      "style": "Collaborative partnership, not sales-focused"
    },
    "key_messages": [
      "Measurable cloud cost optimization (40-62% savings)",
      "Safe AI adoption in regulated environments",
      "Human expertise + technology-driven solutions",
      "Enterprise trust with proven track record",
      "Addressing organizational change drivers"
    ],
    "value_propositions": [
      "Delivering measurable cloud cost savings",
      "Enabling safe Agentic AI deployment",
      "Enterprise governance and compliance",
      "Human-in-the-loop AI solutions",
      "Industry-specific expertise (Financial Services, Legal, Energy, Tech)"
    ],
    "target_markets": [
      "Financial Services",
      "Legal",
      "Energy",
      "Technology",
      "Enterprise (50+ employees)"
    ]
  },
  "assets": {
    "logo": {
      "full": {
        "path": "/branding/assets/finabeo-logo-full.svg",
        "usage": "Primary logo for documents, websites, email headers",
        "variants": ["color", "white", "dark"]
      },
      "mark": {
        "path": "/branding/assets/finabeo-logo-mark.svg",
        "usage": "Icon/mark only for social media, favicons, small spaces",
        "min_width": "60px"
      },
      "favicon": {
        "path": "/branding/assets/finabeo-favicon.ico",
        "usage": "Browser tab, bookmarks"
      }
    },
    "imagery": {
      "style": "Professional, client-focused, metrics-driven",
      "photography": "Real people, enterprise settings, success stories",
      "illustrations": "Modern, minimal, geometric line art"
    }
  },
  "templates": {
    "social_media": {
      "linkedin": {
        "dimensions": "1200x627px",
        "safe_area": "1000x500px",
        "background": "gradient(#003366 to #00B4D8) or solid #003366",
        "text_color": "#FFFFFF",
        "heading_font": "Montserrat Bold 32-48px",
        "body_font": "Open Sans 16-18px"
      },
      "twitter": {
        "dimensions": "1024x512px",
        "background": "solid #003366 or subtle gradient",
        "text_color": "#FFFFFF",
        "heading_font": "Montserrat Bold 28-36px"
      },
      "instagram": {
        "dimensions": "1080x1350px (portrait) or 1080x1080px (square)",
        "background": "bold color blocks using primary + secondary + accent",
        "text_color": "#FFFFFF",
        "heading_font": "Montserrat Bold 36-48px",
        "style": "Bold, stat-focused, high visual impact"
      }
    },
    "document": {
      "word": {
        "page_size": "A4 or Letter",
        "margins": "1 inch all sides",
        "header_height": "1 inch",
        "header_background": "#003366",
        "header_text_color": "#FFFFFF",
        "body_font": "Open Sans 11pt",
        "heading1_font": "Montserrat Bold 18pt",
        "heading1_color": "#003366",
        "heading2_color": "#00B4D8",
        "line_spacing": "1.5"
      },
      "powerpoint": {
        "aspect_ratio": "16:9",
        "slide_background": "#FFFFFF",
        "accent_bar": "#003366 (left or right edge)",
        "title_slide_background": "#003366",
        "title_color": "#FFFFFF",
        "heading_color": "#003366",
        "body_color": "#2B2B2B"
      }
    },
    "email": {
      "max_width": "600px",
      "header_background": "#003366",
      "hero_background": "#FFFFFF",
      "section_background": "#F5F5F5",
      "body_font": "Open Sans 14px",
      "body_color": "#2B2B2B",
      "footer_background": "#2B2B2B",
      "footer_text_color": "#FFFFFF",
      "cta_background": "#00B4D8",
      "cta_text_color": "#FFFFFF"
    }
  },
  "guidelines": {
    "do": [
      "Use primary color (#003366) for trust and stability",
      "Combine with secondary color (#00B4D8) for innovation",
      "Use accent color (#FFB81C) to highlight metrics and ROI",
      "Maintain white space for professional feel",
      "Use Montserrat Bold for headlines to convey confidence",
      "Keep logo clear and uncluttered",
      "Use real client testimonials and success metrics",
      "Emphasize measurable results and impact"
    ],
    "dont": [
      "Don't use color combinations that reduce contrast",
      "Don't stretch or distort logo",
      "Don't use fonts other than Montserrat and Open Sans without approval",
      "Don't use overly bright or neon colors",
      "Don't mix competing design styles",
      "Don't use low-quality imagery",
      "Don't remove Finabeo branding from templates",
      "Don't use aggressive or pushy sales language"
    ]
  },
  "metadata": {
    "created": "2026-04-13",
    "version": "1.0",
    "status": "preliminary",
    "notes": "Based on www.finabeo.com analysis. Awaiting confirmation of actual brand assets (logos, specific colors, fonts). This specification is complete and ready to use with preliminary colors and typography.",
    "last_updated": "2026-04-13",
    "next_steps": [
      "Confirm primary and secondary colors with official brand assets",
      "Provide logo files in SVG format",
      "Confirm font families and licensing",
      "Provide any existing brand guidelines document"
    ]
  }
