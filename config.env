# =============================================================================
# Music Video Noise Removal — Configuration
# =============================================================================
# Scenario: Live orchestra/singing performance recorded on a phone in a hall
# Problems: Metallic hissing from hall reflections, steady background hiss,
#           phone mic picking up reverberant ambience
#
# Adjust these values and re-run ./process.sh to fine-tune results.
# Start with defaults, then tweak one parameter at a time.
# =============================================================================

# --- INPUT / OUTPUT ----------------------------------------------------------
# Filename of the source video inside the input/ directory
INPUT_FILENAME="source.mp4"

# Output filename (placed in output/ directory)
OUTPUT_FILENAME="cleaned.mp4"

# --- STAGE 1: HIGH-PASS / LOW-PASS FILTER -----------------------------------
# Removes low-frequency rumble (room resonance, foot shuffling, HVAC)
# and high-frequency hiss. Cuts frequencies outside the useful range.
#
# HIGHPASS_FREQ: Remove everything below this (Hz). 80-120 good for vocals+orchestra
# LOWPASS_FREQ:  Remove everything above this (Hz). Lowered to 12000 to cut
#                high-frequency metallic reflections from hard hall surfaces.
#                Raise to 14000-16000 if music sounds too dull.
HIGHPASS_FREQ=80
LOWPASS_FREQ=12000

# --- STAGE 2: FFT DENOISE (afftdn) ------------------------------------------
# Reduces steady-state background noise (air conditioning, electrical hum, crowd murmur).
#
# DENOISE_LEVEL: Noise reduction in dB. Higher = more aggressive.
#   Light: 6-10  |  Moderate: 12-18  |  Heavy: 20-30
#   Set to 20 to aggressively target the steady hiss from hall ambience.
DENOISE_LEVEL=20

# Noise type hint for afftdn
#   w = white noise  |  v = vinyl  |  s = shellac  |  o = optimal (auto-detect)
#   "w" works well for the broadband hiss typical of phone mic + hall reflections.
NOISE_TYPE="w"

# --- STAGE 3: METALLIC RESONANCE EQ -----------------------------------------
# Targets the "metallic ringing" caused by high-frequency reflections bouncing
# off hard hall surfaces (walls, ceiling, floor). These resonances typically
# sit in the 2-5kHz range and give the recording a harsh, tinny quality.
#
# Each band is a parametric EQ cut: frequency (Hz), bandwidth (Q), gain (dB).
# Negative gain = cut. Wider Q = broader cut. Adjust by ear.
#
# METAL_EQ_BAND1: Primary harshness band (2-3kHz) — the main metallic ring
# METAL_EQ_BAND2: Upper harshness band (4-5kHz) — sibilant/tinny edge
# METAL_EQ_BAND3: Lower-mid ring (1-1.5kHz) — boxy hall coloration
METAL_EQ_BAND1_FREQ=2500
METAL_EQ_BAND1_Q=1.5
METAL_EQ_BAND1_GAIN=-5

METAL_EQ_BAND2_FREQ=4500
METAL_EQ_BAND2_Q=2.0
METAL_EQ_BAND2_GAIN=-4

METAL_EQ_BAND3_FREQ=1200
METAL_EQ_BAND3_Q=1.0
METAL_EQ_BAND3_GAIN=-3

# --- STAGE 4: DEREVERBERATION (anlmdn) ---------------------------------------
# Non-local means denoising — effective at taming hall reverb tails.
# Works by finding similar audio patterns and averaging them.
#
# DEREVERB_STRENGTH: Strength of reverb suppression (0.0001 - 1.0)
#   Subtle: 0.0001  |  Moderate: 0.001  |  Strong: 0.01
#   For a large hall, start at 0.001 and increase if echo persists.
DEREVERB_STRENGTH=0.001

# Patch radius — controls how much surrounding audio is analyzed for patterns.
#   Range: 0.001 to 0.1
#   Small: 0.01  |  Medium: 0.05  |  Large: 0.1 (catches longer reverb tails)
DEREVERB_PATCH=0.05

# --- STAGE 5: DYNAMIC COMPRESSION -------------------------------------------
# Evens out volume. Lightened since vocals are already clear — just smoothing
# out any level jumps introduced by the EQ and denoise stages.
#
# COMP_THRESHOLD: Level (dB) above which compression kicks in. (-30 to -10)
# COMP_RATIO:     Compression ratio (2 = gentle, 4 = moderate, 8 = heavy)
# COMP_ATTACK:    How fast compressor reacts (ms). 20 for orchestra.
# COMP_RELEASE:   How fast compressor lets go (ms). 250 for natural decay.
COMP_THRESHOLD=-18
COMP_RATIO=2
COMP_ATTACK=20
COMP_RELEASE=250

# --- STAGE 6: LOUDNESS NORMALIZATION ----------------------------------------
# Normalizes final output to broadcast standard loudness.
#
# TARGET_LOUDNESS: Target integrated loudness in LUFS (-16 = loud, -23 = broadcast)
# TRUE_PEAK:       Maximum true peak in dBTP (-1.5 is safe)
TARGET_LOUDNESS=-16
TRUE_PEAK=-1.5

# --- VIDEO SETTINGS ----------------------------------------------------------
# Video codec: "copy" keeps original video untouched (fastest).
# Change to "libx264" only if you also want to re-encode the video.
VIDEO_CODEC="copy"

# Audio codec for output: aac is universally compatible
AUDIO_CODEC="aac"

# Audio bitrate: 192k is good quality, 256k or 320k for higher fidelity
AUDIO_BITRATE="192k"
