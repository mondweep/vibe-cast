# ============================================
# Assamese Video Dubbing Pipeline — Environment Variables
# ============================================
# Copy this file to .env and fill in your keys.
# Without any keys, the app runs in demo mode with pre-translated samples.

# --- Sarvam AI (Primary provider) ---
# Sign up at https://dashboard.sarvam.ai
# Enables: STT (Saaras v3), Translation (sarvam-translate:v1), TTS (Bulbul v3)
SARVAM_API_KEY=

# --- OpenAI (Optional) ---
# Enables: Whisper transcription
OPENAI_API_KEY=

# --- Azure Cognitive Services (Optional) ---
# Enables: TTS (Yashica voice for Assamese), Translator
AZURE_SPEECH_KEY=
AZURE_TRANSLATOR_KEY=

# --- ElevenLabs (Optional) ---
# Enables: Scribe STT, Multilingual TTS
ELEVENLABS_API_KEY=

# --- AI4Bharat Self-Hosted Endpoints (Optional) ---
# Enables: IndicWhisper, IndicTrans2, Parler-TTS/IndicF5
INDICWHISPER_ENDPOINT=
INDICTRANS2_ENDPOINT=
INDIC_TTS_ENDPOINT=

# --- Server Config ---
PORT=3000
