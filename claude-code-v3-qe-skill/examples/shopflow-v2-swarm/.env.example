# ShopFlow V2 Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# DATABASE (Required)
# ===========================================
# Local development:
DATABASE_URL="postgresql://username@localhost:5432/shopflow?schema=public"
# Production (Netlify): Use your hosted PostgreSQL connection string
# Recommended: Neon, Supabase, or Railway for serverless PostgreSQL

# ===========================================
# STRIPE (Required)
# ===========================================
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook Secret:
# - LOCAL: Run `./scripts/stripe-webhook-local.sh` and copy the whsec_... value
# - PRODUCTION: Create webhook in Stripe Dashboard and copy the signing secret
#   Dashboard > Developers > Webhooks > Add endpoint
#   URL: https://your-site.netlify.app/api/webhooks/stripe
#   Events: checkout.session.completed, payment_intent.succeeded, payment_intent.payment_failed
STRIPE_WEBHOOK_SECRET="whsec_..."

# ===========================================
# EMAIL (Required for order confirmations)
# ===========================================
# Get from https://resend.com/api-keys
RESEND_API_KEY="re_..."

# ===========================================
# APP CONFIGURATION
# ===========================================
# Local development:
NEXT_PUBLIC_APP_URL="http://localhost:3002"
# Production: Your Netlify URL
# NEXT_PUBLIC_APP_URL="https://your-site.netlify.app"

NODE_ENV="development"

# ===========================================
# OPTIONAL
# ===========================================
# Redis for caching (not required)
# REDIS_URL="redis://localhost:6379"
