# Driftwise Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: Gemini API Key
# =============================================================================
# Get your API key from: https://aistudio.google.com/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# OPTIONAL: Configuration Overrides
# =============================================================================

# Nominatim User Agent (required by Nominatim ToS)
VITE_NOMINATIM_USER_AGENT=Driftwise/1.0

# Default polling interval in milliseconds (default: 300000 = 5 minutes)
VITE_DEFAULT_POLLING_INTERVAL_MS=300000

# Minimum polling interval in milliseconds (default: 120000 = 2 minutes)
VITE_MIN_POLLING_INTERVAL_MS=120000

# Maximum polling interval in milliseconds (default: 900000 = 15 minutes)
VITE_MAX_POLLING_INTERVAL_MS=900000

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Enable debug logging (default: false)
VITE_DEBUG=false

# Mock location for testing (format: "lat,lon")
# VITE_MOCK_LOCATION=51.5074,-0.1278

# Skip Gemini API calls and use mock data (default: false)
# VITE_MOCK_GEMINI=false
